// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../src/generated"
}

datasource db {
  provider = "mysql"
}

//////////////////////////
// ENUMS
//////////////////////////

enum Role {
  SUPER_ADMIN
  ADMIN
  USER
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

//////////////////////////
// USER
//////////////////////////

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  password      String
  role          Role      @default(USER)
  isVerified    Boolean   @default(false)
  resetToken    String?
  resetTokenExp DateTime?

  examAttempts  ExamAttempt[]
  topicProgress TopicProgress[]

  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  bookmarks Bookmark[]
}

//////////////////////////
// EXAM TYPE
//////////////////////////

model ExamType {
  id        String  @id @default(uuid())
  name      String  @unique
  hasStages Boolean @default(true)
  isActive  Boolean @default(true)

  stages   ExamStage[]
  subjects Subject[] // direct subjects if no stages

  createdAt DateTime @default(now())
}

//////////////////////////
// EXAM STAGE
//////////////////////////

model ExamStage {
  id   String @id @default(uuid())
  name String

  examTypeId String
  examType   ExamType @relation(fields: [examTypeId], references: [id], onDelete: Cascade)

  subjects    Subject[]
  examConfigs ExamConfig[]
  attempts    ExamAttempt[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @default(now()) @updatedAt
  isActive    Boolean       @default(true)

  @@unique([name, examTypeId])
}

//////////////////////////
// SUBJECT
//////////////////////////

model Subject {
  id   String @id @default(uuid())
  name String

  // Optional stage (for exams WITH stages)
  stageId String?
  stage   ExamStage? @relation(fields: [stageId], references: [id], onDelete: Cascade)

  // Always linked to exam type
  examTypeId String
  examType   ExamType @relation(fields: [examTypeId], references: [id], onDelete: Cascade)

  topics    Topic[]
  bookmarks Bookmark[]

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@unique([name, examTypeId, stageId])
}

//////////////////////////
// TOPIC
//////////////////////////

model Topic {
  id   String @id @default(uuid())
  name String

  subjectId String
  subject   Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  questions Question[]
  progress  TopicProgress[]

  order     Int        @default(0)
  isActive  Boolean    @default(true)
  bookmarks Bookmark[]

  @@unique([name, subjectId])
}

//////////////////////////
// QUESTION
//////////////////////////

model Question {
  id            String     @id @default(uuid())
  question      String
  optionA       String
  optionB       String
  optionC       String
  optionD       String
  correct       String
  explanation   String?
  difficulty    Difficulty
  marks         Float      @default(1)
  negativeMarks Float      @default(0)
  year          Int?
  isPYQ         Boolean    @default(false)
  language      String     @default("EN")

  topicId String
  topic   Topic  @relation(fields: [topicId], references: [id], onDelete: Cascade)

  tags QuestionTag[]

  createdAt DateTime   @default(now())
  bookmarks Bookmark[]
}

//////////////////////////
// TAGS
//////////////////////////

model Tag {
  id        String        @id @default(uuid())
  name      String        @unique
  questions QuestionTag[]
}

model QuestionTag {
  questionId String
  tagId      String

  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  tag      Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([questionId, tagId])
}

//////////////////////////
// EXAM CONFIG
//////////////////////////

model ExamConfig {
  id String @id @default(uuid())

  stageId String
  stage   ExamStage @relation(fields: [stageId], references: [id], onDelete: Cascade)

  totalQuestions  Int
  durationMinutes Int
  negativeMarking Boolean @default(false)
  isActive        Boolean @default(true)
}

//////////////////////////
// EXAM ATTEMPT
//////////////////////////

model ExamAttempt {
  id String @id @default(uuid())

  userId String
  user   User   @relation(fields: [userId], references: [id])

  stageId   String
  stage     ExamStage @relation(fields: [stageId], references: [id])
  topicId   String
  total     Int
  correct   Int
  wrong     Int
  score     Float
  timeTaken Int
  answers   Json

  createdAt DateTime @default(now())
}

//////////////////////////
// TOPIC PROGRESS
//////////////////////////

model TopicProgress {
  id String @id @default(uuid())

  userId  String
  topicId String

  user  User  @relation(fields: [userId], references: [id])
  topic Topic @relation(fields: [topicId], references: [id])

  attempted Int   @default(0)
  correct   Int   @default(0)
  wrong     Int   @default(0)
  accuracy  Float @default(0)

  @@unique([userId, topicId])
}

//////////////////////////
// book mark
//////////////////////////

model Bookmark {
  id String @id @default(uuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  questionId String
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  topicId String
  topic   Topic  @relation(fields: [topicId], references: [id], onDelete: Cascade)

  subjectId String
  subject   Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, questionId])
}

